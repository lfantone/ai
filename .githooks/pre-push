#!/usr/bin/env bash
# Pre-push gate:
#   1. Regenerates .opencode/ from the canonical catalog, so the generated config can
#      never drift out of sync with agents/ and commands/.
#   2. Formats all Markdown with Prettier.
# If either step changes anything, the push is aborted so the changes can be reviewed
# and committed — the commit being pushed is already fixed by this point.
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# Keep the generated OpenCode config in sync with the canonical agents/commands.
if [ -x scripts/build-opencode.sh ]; then
  echo "pre-push: regenerating .opencode/ from the canonical catalog..."
  ./scripts/build-opencode.sh >/dev/null
fi

# No package install → skip formatting rather than block the push.
if [ ! -x node_modules/.bin/prettier ]; then
  echo "pre-push: prettier not installed; run 'npm install' to enable Markdown formatting. Skipping." >&2
else
  echo "pre-push: formatting Markdown with prettier..."
  node_modules/.bin/prettier --write --log-level warn "**/*.md"
fi

# Abort if regeneration or formatting changed any tracked file (or produced new ones).
if ! git diff --quiet -- '*.md' || [ -n "$(git status --porcelain -- '*.md' | grep '^??' || true)" ]; then
  echo >&2
  echo "pre-push: files were regenerated/reformatted. Review and commit, then push again:" >&2
  git status --short -- '*.md' >&2
  exit 1
fi

echo "pre-push: catalog in sync and formatted."
